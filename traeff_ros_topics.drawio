        <mxCell id="h68yPervqvKu_4Ycb5cH-17" parent="1" style="shape=process;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="rviz" vertex="1">
          <mxGeometry height="30" width="80" x="260" y="495" as="geometry" />
